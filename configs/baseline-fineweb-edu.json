{
  "run": {
    "name": "baseline-fineweb-edu",
    "log_interval": 10,
    "save_interval": 5000,
    "seed": 42
  },
  "dataset": {
    "dataset_folders": ["fineweb-edu-10b"],
    "dataset_weights": [1.0]
  },
  "model": {
    "model": "gptv4",
    "config": {
      "block_size": 1024,
      "n_heads": 12,
      "n_embed": 768,
      "n_layers": 12,
      "n_kv_heads": 4
    }
  },
  "optimizer": {
    "max_lr": 3e-4,
    "min_lr": 3e-5,
    "warmup_steps": 1000,
    "weight_decay": 0.1,
    "schedule": "cosine",
    "adam_b1": 0.9,
    "adam_b2": 0.95,
    "adam_eps": 1e-8
  },
  "tokenizer": {
    "path": "vocabs/vocab_fineweb-edu_32768.json"
  },
  "tokens": {
    "batch_size": 16,
    "grad_accum_steps": 4,
    "train_tokens": 9652000000
  },
  "eval": {
    "interval": 500,
    "batches": 20
  }
}
