{
  "run": {
    "name": "v4.0.2.arch-baseline",
    "log_interval": 10,
    "save_interval": 500,
    "seed": 42,
    "description": "42 layers, 16 n_heads, ~500M parameters."
  },
  "dataset": {
    "dataset_folders": ["fineweb-edu-10b"],
    "dataset_weights": [1.0]
  },
  "model": {
    "model": "gptv4",
    "config": {
      "block_size": 1024,
      "n_embed": 1024,
      "n_heads": 16,
      "n_layers": 42,
      "n_kv_heads": 4
    }
  },
  "optimizer": {
    "max_lr": 3e-4,
    "min_lr": 3e-5,
    "warmup_steps": 250,
    "weight_decay": 0.1,
    "schedule": "linear",
    "decay_frac": 0.0,
    "adam_b1": 0.9,
    "adam_b2": 0.95,
    "adam_eps": 1e-8
  },
  "tokenizer": {
    "path": "data/vocabs/vocab_fineweb_32k.json"
  },
  "tokens": {
    "batch_size": 32,
    "grad_accum_steps": 16,
    "train_steps": 4000
  },
  "val_loss": {
    "interval": 50,
    "batches": 20
  }
}
