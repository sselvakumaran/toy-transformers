{
  "run": {
    "name": "v4.0.1.bs512",
    "log_interval": 10,
    "save_interval": 500,
    "seed": 42,
    "description": "LR x batch ablation — global batch 512, LR 3e-4 fixed, ~1B tokens, WSD 20% decay."
  },
  "dataset": {
    "dataset_folders": ["fineweb-edu-10b"],
    "dataset_weights": [1.0]
  },
  "model": {
    "model": "gptv4",
    "config": {
      "block_size": 1024,
      "n_embed": 1152,
      "n_heads": 16,
      "n_layers": 36,
      "n_kv_heads": 4
    }
  },
  "optimizer": {
    "max_lr": 3e-4,
    "min_lr": 3e-5,
    "warmup_steps": 25,
    "weight_decay": 0.1,
    "schedule": "linear",
    "decay_frac": 0.2,
    "adam_b1": 0.9,
    "adam_b2": 0.95,
    "adam_eps": 1e-8
  },
  "tokenizer": {
    "path": "data/vocabs/vocab_fineweb_32k.json"
  },
  "tokens": {
    "batch_size": 8,
    "grad_accum_steps": 64,
    "train_steps": 1907
  },
  "val_loss": {
    "interval": 50,
    "batches": 20
  }
}
