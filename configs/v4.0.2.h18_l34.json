{
  "run": {
    "name": "v4.0.2.h16_l42",
    "log_interval": 10,
    "save_interval": 2500,
    "seed": 42,
    "description": "ablation for 18 heads, 34 layers. this sweep uses relu^2 and GQA w/ 2heads"
  },
  "dataset": {
    "dataset_folders": ["fineweb-edu-10b"],
    "dataset_weights": [1.0]
  },
  "model": {
    "model": "gptv4",
    "config": {
      "block_size": 1024,
      "n_embed": 1152,
      "n_heads": 18,
      "n_layers": 34,
      "n_kv_heads": 2
    }
  },
  "optimizer": {
    "max_lr": 3e-4,
    "min_lr": 3e-5,
    "warmup_steps": 250,
    "weight_decay": 0.1,
    "schedule": "linear",
    "decay_frac": 0.0,
    "adam_b1": 0.9,
    "adam_b2": 0.95,
    "adam_eps": 1e-8
  },
  "tokenizer": {
    "path": "data/vocabs/vocab_fineweb_32k.json"
  },
  "tokens": {
    "batch_size": 128,
    "grad_accum_steps": 4,
    "train_steps": 2000
  },
  "val_loss": {
    "interval": 50,
    "batches": 20
  }
}
