{
  "run": {
    "name": "v4.0.1",
    "log_interval": 10,
    "save_interval": 1000,
    "seed": 42,
    "description": "Updated to semantic reasoning, bumped up n_layers to 16 and change to WSD schedule for ablations."
  },
  "dataset": {
    "dataset_folders": ["fineweb-edu-10b"],
    "dataset_weights": [1.0]
  },
  "model": {
    "model": "gptv4",
    "config": {
      "block_size": 1024,
      "n_heads": 12,
      "n_embed": 768,
      "n_layers": 16,
      "n_kv_heads": 4
    }
  },
  "optimizer": {
    "max_lr": 3e-4,
    "min_lr": 3e-5,
    "warmup_steps": 200,
    "weight_decay": 0.1,
    "schedule": "linear",
    "decay_frac": 0,
    "adam_b1": 0.9,
    "adam_b2": 0.95,
    "adam_eps": 1e-8
  },
  "tokenizer": {
    "path": "data/vocabs/vocab_fineweb_32k.json"
  },
  "tokens": {
    "batch_size": 64,
    "grad_accum_steps": 4,
    "train_steps": 5000
  },
  "val_loss": {
    "interval": 100,
    "batches": 20
  }
}
